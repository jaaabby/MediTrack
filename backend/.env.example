# ============================================
# Meditrack - Configuración de Entorno
# ============================================
# Copia este archivo a .env y ajusta los valores según tu entorno

# ============================================
# Base de Datos PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=meditrack
DB_SSL_MODE=disable

# ============================================
# Servidor Backend
# ============================================
PORT=8080
HTTPS_PORT=8443
ENV=development

# ============================================
# JWT Configuration
# ============================================
# IMPORTANTE: Cambia estas claves en producciÃ³n
# Genera claves seguras con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=text

# ============================================
# CORS Configuration
# ============================================
# OrÃ­genes permitidos separados por comas
CORS_ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000,https://localhost:5173,http://localhost:5173

# ============================================
# Passkey / WebAuthn
# ============================================
# Debe coincidir con el dominio desde donde se abre el frontend
WEBAUTHN_RPID=localhost
# Origenes permitidos por WebAuthn (separados por comas)
WEBAUTHN_ORIGINS=https://localhost:3000,http://localhost:3000,https://localhost:5173,http://localhost:5173

# ============================================
# Configuración de HTTPS/Certificados
# ============================================
# IP del host para generar certificados SSL (ej: 192.168.1.100)
# Si no se especifica, se detecta automáticamente
HOST_IP=

# Host del API para configuración automática (ej: 192.168.1.100:8443)
# Si no se especifica, se detecta automáticamente desde el request
API_HOST=

# IPs adicionales para incluir en el certificado (separadas por comas)
# Ejemplo: CERT_IPS=192.168.1.100,192.168.1.101
CERT_IPS=

# DNS adicionales para incluir en el certificado (separadas por comas)
# Ejemplo: CERT_DNS=meditrack.local,api.meditrack.local
CERT_DNS=

# ============================================
# Email Configuration (SMTP)
# ============================================
# Configuración para envío de emails (alertas, notificaciones)
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_DIR=tu-email@gmail.com
EMAIL_PASS=tu-app-password-aqui
EMAIL_FROM_NAME=Meditrack

# Nota: Para Gmail, necesitas generar una "Contraseña de aplicación":
# 1. Ve a tu cuenta de Google → Seguridad
# 2. Activa verificación en 2 pasos
# 3. Genera una "Contraseña de aplicación"
# 4. Usa esa contraseña en EMAIL_PASS

# ============================================
# Notificaciones de Insumos No Consumidos
# ============================================
# Intervalo de reenvío de notificaciones en horas (por defecto: 2.0)
# Ejemplos: 0.5 = 30 min, 1.0 = 1 hora, 2.0 = 2 horas, 12.0 = 12 horas
NOTIFICATION_RESEND_INTERVAL_HOURS=3.0

# ============================================
# Redis Configuration (Opcional)
# ============================================
# Redis se usa para caché y sesiones (opcional para desarrollo)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=3000

# URL del frontend para generar enlaces en emails (recuperación de contraseña, etc.)
# Si no se especifica, se auto-detecta desde los headers de la petición
# En desarrollo: http://localhost:3000 (si usas Vite con puerto 3000)
# En producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:3000