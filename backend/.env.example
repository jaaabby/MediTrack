# ============================================
# MediTrack - ConfiguraciÃ³n de Entorno
# ============================================
# Copia este archivo a .env y ajusta los valores segÃºn tu entorno

# ============================================
# Base de Datos PostgreSQL
# ============================================
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=meditrack
DB_SSL_MODE=disable

# ============================================
# Servidor Backend
# ============================================
PORT=8080
HTTPS_PORT=8443
ENV=production

# ============================================
# JWT Configuration
# ============================================
# IMPORTANTE: Cambia estas claves en producciÃ³n
# Genera claves seguras con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# CORS Configuration
# ============================================
# OrÃ­genes permitidos separados por comas
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://localhost:5173

# ============================================
# Configuración de HTTPS/Certificados
# ============================================
# IP del host para generar certificados SSL (ej: 192.168.1.100)
# Si no se especifica, se detecta automáticamente
HOST_IP=

# Host del API para configuración automática (ej: 192.168.1.100:8443)
# Si no se especifica, se detecta automáticamente desde el request
API_HOST=

# IPs adicionales para incluir en el certificado (separadas por comas)
# Ejemplo: CERT_IPS=192.168.1.100,192.168.1.101
CERT_IPS=

# DNS adicionales para incluir en el certificado (separadas por comas)
# Ejemplo: CERT_DNS=meditrack.local,api.meditrack.local
CERT_DNS=

# ============================================
# Email Configuration (SMTP)
# ============================================
# Configuración para envío de emails (alertas, notificaciones)
# Deja vacío si no necesitas funcionalidad de email
EMAIL_DIR=
EMAIL_PASS=
EMAIL_SERVER=
EMAIL_PORT=

# Ejemplo para Gmail:
# EMAIL_DIR=tu-email@gmail.com
# EMAIL_PASS=tu-app-password
# EMAIL_SERVER=smtp.gmail.com
# EMAIL_PORT=587

# ============================================
# Notificaciones de Insumos No Consumidos
# ============================================
# Intervalo de reenvío de notificaciones en horas (por defecto: 2.0)
# Ejemplos: 0.5 = 30 min, 1.0 = 1 hora, 2.0 = 2 horas, 12.0 = 12 horas
NOTIFICATION_RESEND_INTERVAL_HOURS=2.0

# ============================================
# Redis Configuration (Opcional)
# ============================================
# Redis se usa para cachÃ© y sesiones (opcional)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Frontend Port
# ============================================
FRONTEND_PORT=3000