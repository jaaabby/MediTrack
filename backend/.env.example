# ============================================
# MediTrack - ConfiguraciÃ³n de Entorno
# ============================================
# Copia este archivo a .env y ajusta los valores segÃºn tu entorno

# ============================================
# Base de Datos PostgreSQL
# ============================================
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=meditrack
DB_SSL_MODE=disable

# ============================================
# Servidor Backend
# ============================================
PORT=8080
ENV=production

# ============================================
# JWT Configuration
# ============================================
# IMPORTANTE: Cambia estas claves en producciÃ³n
# Genera claves seguras con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# CORS Configuration
# ============================================
# OrÃ­genes permitidos separados por comas
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# Email Configuration (SMTP)
# ============================================
# ConfiguraciÃ³n para envÃ­o de emails (alertas, notificaciones)
# Deja vacÃ­o si no necesitas funcionalidad de email
EMAIL_DIR=
EMAIL_PASS=
EMAIL_SERVER=
EMAIL_PORT=

# Ejemplo para Gmail:
# EMAIL_DIR=tu-email@gmail.com
# EMAIL_PASS=tu-app-password
# EMAIL_SERVER=smtp.gmail.com
# EMAIL_PORT=587

# ============================================
# Redis Configuration (Opcional)
# ============================================
# Redis se usa para cachÃ© y sesiones (opcional)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Frontend Port
# ============================================
FRONTEND_PORT=3000